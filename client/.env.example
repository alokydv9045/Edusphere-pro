# ── client/.env.example ──────────────────────────────────────────────────────
# Documentation for required environment variables for the EduSphere Client

# ── API Connection ──────────────────────────────────────────────────
# The URL of your backend API (the server Render URL)
# MUST NOT end with a "/" after /api
# Example for Render: https://edusphere-api.onrender.com/api
NEXT_PUBLIC_API_URL=https://your-api-name.onrender.com/api

# ── Local Development Config ───────────────────────────────────────
# Default port if not 3000
PORT=3000

# ── Features & Config ───────────────────────────────────────────────
# (Optional) Any specific frontend feature flags
# SCHOOL_NAME=EduSphere Academy
